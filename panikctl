#!/bin/sh

PANIK_MODULE="/lib/modules/$(uname -r)/extra/panik.ko"

if [ ! -e "$PANIK_MODULE" ]; then
    echo "ERROR: panik module not found"
    exit 1
fi

if ! command -v modprobe >/dev/null 2>&1; then
    echo "ERROR: modprobe not found"
    exit 1
fi

if [ "$(id -u)" -ne 0 ]; then
    echo "ERROR: not root"
    exit 1
fi

if [ -z "$1" ]; then
    echo "ERROR: no panik message specified"
    exit 1
fi

printf '%s\n' "$*" > /tmp/panik

modprobe panik

sleep 1

echo "ERROR: kernel did not panic"
dmesg
exit 1
